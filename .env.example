# -----------------------------------------------------------------------
# .env.example – copy to .env and fill in your values
# -----------------------------------------------------------------------

# Path to your downloaded Vosk model directory
# Download from: https://alphacephei.com/vosk/models
VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15

# Set to true to enable the optional local LLM fallback (needs Ollama running)
USE_LOCAL_LLM=false

# Ollama model name (e.g. mistral, llama3, phi3)
OLLAMA_MODEL=mistral

# Ollama API base URL
OLLAMA_URL=http://localhost:11434/api/generate

# Set to true to enable developer-mode actions (run files, git, VS Code)
DEVELOPER_MODE=false

# Absolute path to VS Code CLI (only needed if not already on system PATH)
# VSCODE_PATH=C:\Users\YourName\AppData\Local\Programs\Microsoft VS Code\bin\code.cmd
